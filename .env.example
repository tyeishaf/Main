# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # safe for the browser; RLS protects data

# Server-only: cron jobs & webhooks (Phase 7). NEVER prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Phase 7: Automations ──
CRON_SECRET=generate-a-long-random-string
LEADS_WEBHOOK_KEY=another-long-random-string

# Twilio (texting)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Gmail (sending as you)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM=you@gmail.com

# Vendor polling (only if not using the webhook — see SETUP.md)
VANILLASOFT_API_URL=
VANILLASOFT_API_KEY=
TEXTDRIP_API_URL=
TEXTDRIP_API_KEY=

# ── Phase 8: AI assistant ──
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6   # optional override

# Phase 13 — Google Calendar (read-only)
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
